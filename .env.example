# --- Ops Cockpit: relevante Umgebungswerte ---
APP_NAME="Ops Cockpit"
APP_ENV=production
APP_KEY=                      # php artisan key:generate  (wichtig: verschlüsselt Secrets/Lizenzen at rest!)
APP_DEBUG=false
APP_URL=https://dashboard.deineagentur.at

# Datenbank (Mittwald: eigenes, isoliertes Projekt + eigene DB)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ops_cockpit
DB_USERNAME=ops_cockpit
DB_PASSWORD=

# Queue/Cache: für MVP 'database' ausreichend; Redis optional später.
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true

# Hinweis: APP_KEY NIE verlieren – ohne ihn sind verschlüsselte Site-Secrets
# und Lizenzschlüssel nicht mehr entschlüsselbar.
